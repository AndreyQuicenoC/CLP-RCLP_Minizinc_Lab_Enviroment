% ============================================================================
% CLP Test Case: 0_0 (variant: 0_0)
% ============================================================================
% Source: JITS2022 Test Battery
% Original file: buses_input_0_0.json
% Converted to INTEGER CLP format with SCALE=10
%
% CONVERSION DETAILS:
% - All floating-point values multiplied by 10 and rounded to integers
% - Example: 42.5 minutes → 425 (integer)
%           1.3 kWh → 13 (integer)
%
% IMPORTANT: To interpret results, divide integer values by 10:
%   - Time: integer_value / 10 = minutes
%   - Energy: integer_value / 10 = kWh
% ============================================================================

% --- Problem Dimensions ---
num_buses = 2;
num_stations = 12;

% --- Energy Parameters (CLP Model) ---
% All values are INTEGERS scaled by ×10 from original floating-point values
Cmax = 1000;  % Maximum battery capacity (original: 100.0 kWh)
Cmin = 200;   % Minimum reserve (original: 20.0 kWh)
alpha = 100;  % Fast charging rate (original: 10.0 kWh per minute)

% --- Time and Schedule Parameters ---
% All values are INTEGERS scaled by ×10 from original floating-point values
mu = 50;      % Maximum delay allowed (original: 5.0 minutes)
SM = 10;      % Safety margin (original: 1.0 minutes)
psi = 10;     % Minimum charging time (original: 1.0 minutes)
beta = 100;   % Maximum charging time per stop (original: 10.0 minutes)
M = 100000;   % Big-M constant (original: 10000.0)

% --- Route Structure ---
max_stops = 9;
num_stops = [9, 8];

% --- Station Sequence (st_bi) ---
% Maps each bus stop to a physical station ID (1-indexed)
st_bi = array2d(1..2, 1..9, [
  1,2,3,4,5,6,7,8,12,  % Bus 1
  9,10,7,11,9,10,7,11,11  % Bus 2
]);

% --- Energy Consumption (D) ---
% Energy consumed between stops (INTEGER values, divide by 10 for kWh)
% Original floating-point values have been scaled by ×10
D = array2d(1..2, 1..9, [
  0,8,12,3,2,4,16,2,2,  % Bus 1
  0,3,4,10,18,4,4,13,0  % Bus 2
]);

% --- Travel Time (T) ---
% Time between stops (INTEGER values, divide by 10 for minutes)
% Original floating-point values have been scaled by ×10
T = array2d(1..2, 1..9, [
  0,50,80,20,10,30,110,10,10,  % Bus 1
  0,20,30,70,120,30,30,90,0  % Bus 2
]);

% --- Original Timetable (tau_bi) ---
% Scheduled arrival times (INTEGER values, divide by 10 for minutes since 00:00)
% Original floating-point values have been scaled by ×10
tau_bi = array2d(1..2, 1..9, [
  0,50,130,150,160,190,300,310,320,  % Bus 1
  0,20,50,120,240,270,300,390,390  % Bus 2
]);
