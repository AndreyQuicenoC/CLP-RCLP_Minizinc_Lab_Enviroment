% Minimal feasible test: 1 bus, 2 stations, 2 stops
% Designed to be trivially satisfiable

num_buses = 1;
num_stations = 2;
max_stops = 2;

num_stops = [2];

% Station mapping: Bus 0 visits stations 1, 2
st_bi = [| 1, 2 |];

% Battery parameters
Cmax = 1000;       % 100 kWh
Cmin = 200;         % 20 kWh
alpha = 100;        % 10 kWh/min

% Time parameters
mu = 100;           % 10 min max deviation (relaxed)
psi = 10;           % 1 min minimum charging
SM = 10;            % 1 min safety margin
beta = 100;         % 10 min max charging
M = 10000;

% Energy: Very small consumption (doesn't force charging)
D = [| 0, 100 |];   % 10 kWh between stops

% Travel: Very fast
T = [| 0, 60 |];     % 6 minutes

% Schedule: Simple, widely spaced
tau_bi = [| 0, 200 |];  % Plenty of time between stops
