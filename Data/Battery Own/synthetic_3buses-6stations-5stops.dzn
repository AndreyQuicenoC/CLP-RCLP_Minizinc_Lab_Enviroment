% ============================================================================
% Synthetic Test Case: synthetic_3buses-6stations-5stops (CORRECTED)
% ============================================================================
% All values are INTEGERS scaled by ×10
% Station 1 is used as depot (start point, never needs charging)
% ============================================================================

% --- Problem Dimensions ---
num_buses = 3;
num_stations = 6;

% --- Energy Parameters (Scaled ×10) ---
Cmax = 1000;  % 100 kWh max capacity
Cmin = 200;   % 20 kWh minimum reserve (80 kWh usable)
alpha = 100;  % 10 kWh/min charging rate

% --- Time Parameters (Scaled ×10) ---
mu = 50;      % 5 min max delay
SM = 10;      % 1 min safety margin
psi = 10;     % 1 min minimum charging time
beta = 100;   % 10 min maximum charging time
M = 100000;   % Big-M constant

% --- Route Structure ---
max_stops = 5;
num_stops = [5, 5, 4];

% --- Station Sequence (st_bi) ---
% Station 1 = depot (D=0, T=0, no charging needed)
% Corrected: no index 0, proper padding with last valid station
st_bi = array2d(1..3, 1..5, [
  1,5,2,2,3,  % Bus 1: depot -> 5 -> 2 -> 2 -> 3 (needs charging at station 2 or 3)
  1,2,3,6,4,  % Bus 2: depot -> 2 -> 3 -> 6 -> 4 (needs charging)
  1,5,4,4,4   % Bus 3: depot -> 5 -> 4 (padding with station 4)
]);

% --- Energy Consumption (D) ---
% Scaled ×10 (kWh × 10)
% Total consumption exceeds usable capacity (80 kWh) to force charging
D = array2d(1..3, 1..5, [
  0,250,300,200,150,  % Bus 1: 900 total (90 kWh) - MUST charge
  0,300,250,200,150,  % Bus 2: 900 total (90 kWh) - MUST charge
  0,400,300,0,0       % Bus 3: 700 total (70 kWh) - might need charging
]);

% --- Travel Time (T) ---
% Scaled ×10 (minutes × 10)
T = array2d(1..3, 1..5, [
  0,150,180,150,120,  % Bus 1
  0,180,200,150,100,  % Bus 2
  0,200,180,0,0       % Bus 3
]);

% --- Timetable (tau_bi) ---
% Scaled ×10 (minutes × 10)
% Starting at 7:00 AM (4200 = 420.0 minutes = 7:00)
tau_bi = array2d(1..3, 1..5, [
  4200,4350,4530,4680,4800,  % Bus 1
  4200,4380,4580,4730,4830,  % Bus 2
  4200,4400,4580,4580,4580   % Bus 3
]);
