% ============================================================================
% Synthetic Test Case: synthetic_10buses-20stations-12stops (CORRECTED)
% ============================================================================
% All values are INTEGERS scaled by ×10
% Station 1 is used as depot (start point, never needs charging)
% ============================================================================

% --- Problem Dimensions ---
num_buses = 10;
num_stations = 20;

% --- Energy Parameters (Scaled ×10) ---
Cmax = 1000;  % 100 kWh max capacity
Cmin = 200;   % 20 kWh minimum reserve (80 kWh usable)
alpha = 100;  % 10 kWh/min charging rate

% --- Time Parameters (Scaled ×10) ---
mu = 50;      % 5 min max delay
SM = 10;      % 1 min safety margin
psi = 10;     % 1 min minimum charging time
beta = 100;   % 10 min maximum charging time
M = 100000;   % Big-M constant

% --- Route Structure ---
max_stops = 12;
num_stops = [6, 10, 9, 7, 9, 6, 8, 10, 12, 11];

% --- Station Sequence (st_bi) ---
% Station 1 = depot, corrected indices, proper padding
st_bi = array2d(1..10, 1..12, [
  1,10,18,15,13,11,11,11,11,11,11,11,  % Bus 1: 6 stops + padding
  1,9,14,20,7,13,17,14,6,5,5,5,  % Bus 2: 10 stops + padding (removed 0s)
  1,19,5,2,3,19,17,12,16,16,16,16,  % Bus 3: 9 stops + padding
  1,19,14,7,17,14,8,8,8,8,8,8,  % Bus 4: 7 stops + padding
  1,10,15,14,8,3,8,19,12,12,12,12,  % Bus 5: 9 stops + padding
  1,14,6,12,10,4,4,4,4,4,4,4,  % Bus 6: 6 stops + padding
  1,17,7,14,18,11,12,10,10,10,10,10,  % Bus 7: 8 stops + padding
  1,20,12,9,2,3,13,16,3,4,4,4,  % Bus 8: 10 stops + padding (removed 0s)
  1,15,8,16,14,12,16,12,17,13,7,3,  % Bus 9: 12 stops
  1,2,19,14,8,11,10,2,18,9,11,11  % Bus 10: 11 stops + padding (removed 0)
]);

% --- Energy Consumption (D) ---
% Scaled ×10 (kWh × 10), increased to force charging
D = array2d(1..10, 1..12, [
  0,200,180,250,250,180,0,0,0,0,0,0,  % Bus 1: 1060
  0,250,180,250,180,250,220,180,220,300,0,0,  % Bus 2: 2030
  0,180,200,180,300,180,180,220,220,0,0,0,  % Bus 3: 1660
  0,180,220,300,220,180,250,0,0,0,0,0,  % Bus 4: 1350
  0,220,300,180,220,180,180,220,180,0,0,0,  % Bus 5: 1680
  0,180,250,250,220,250,0,0,0,0,0,0,  % Bus 6: 1150
  0,250,180,250,180,180,300,220,0,0,0,0,  % Bus 7: 1560
  0,250,220,180,250,180,220,180,250,180,0,0,  % Bus 8: 1910
  0,220,300,300,250,220,180,180,180,250,300,180,  % Bus 9: 2560
  0,300,220,180,180,250,300,180,220,180,220,0  % Bus 10: 2230
]);

% --- Travel Time (T) ---
% Scaled ×10 (minutes × 10)
T = array2d(1..10, 1..12, [
  0,180,200,120,200,200,0,0,0,0,0,0,  % Bus 1
  0,160,240,120,140,180,170,140,140,170,0,0,  % Bus 2
  0,240,170,240,240,130,100,100,120,0,0,0,  % Bus 3
  0,140,240,190,200,190,140,0,0,0,0,0,  % Bus 4
  0,230,140,190,220,240,190,160,130,0,0,0,  % Bus 5
  0,130,190,220,190,180,0,0,0,0,0,0,  % Bus 6
  0,170,120,100,190,240,240,180,0,0,0,0,  % Bus 7
  0,180,170,180,140,100,220,100,120,150,0,0,  % Bus 8
  0,130,100,170,190,240,140,140,130,180,130,140,  % Bus 9
  0,190,150,230,230,150,230,160,170,170,120,0  % Bus 10
]);

% --- Timetable (tau_bi) ---
% Scaled ×10 (minutes × 10), starting at 7:00 AM (4200)
tau_bi = array2d(1..10, 1..12, [
  4200,4380,4580,4700,4900,5100,5100,5100,5100,5100,5100,5100,  % Bus 1
  4200,4360,4600,4720,4860,5040,5210,5350,5490,5660,5660,5660,  % Bus 2
  4200,4440,4610,4850,5090,5220,5320,5420,5540,5540,5540,5540,  % Bus 3
  4200,4340,4580,4770,4970,5160,5300,5300,5300,5300,5300,5300,  % Bus 4
  4200,4430,4570,4760,4980,5220,5410,5570,5700,5700,5700,5700,  % Bus 5
  4200,4330,4520,4740,4930,5110,5110,5110,5110,5110,5110,5110,  % Bus 6
  4200,4370,4490,4590,4780,5020,5260,5440,5440,5440,5440,5440,  % Bus 7
  4200,4380,4550,4730,4870,4970,5190,5290,5410,5560,5560,5560,  % Bus 8
  4200,4330,4430,4600,4790,5030,5170,5310,5440,5620,5750,5890,  % Bus 9
  4200,4390,4540,4770,5000,5150,5380,5540,5710,5880,5980,5980  % Bus 10
]);
