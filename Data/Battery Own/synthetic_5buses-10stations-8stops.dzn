% ============================================================================
% Synthetic Test Case: synthetic_5buses-10stations-8stops (CORRECTED)
% ============================================================================
% All values are INTEGERS scaled by ×10
% Station 1 is used as depot (start point, never needs charging)
% ============================================================================

% --- Problem Dimensions ---
num_buses = 5;
num_stations = 10;

% --- Energy Parameters (Scaled ×10) ---
Cmax = 1000;  % 100 kWh max capacity
Cmin = 200;   % 20 kWh minimum reserve (80 kWh usable)
alpha = 100;  % 10 kWh/min charging rate

% --- Time Parameters (Scaled ×10) ---
mu = 50;      % 5 min max delay
SM = 10;      % 1 min safety margin
psi = 10;     % 1 min minimum charging time
beta = 100;   % 10 min maximum charging time
M = 100000;   % Big-M constant

% --- Route Structure ---
max_stops = 8;
num_stops = [6, 5, 5, 8, 6];

% --- Station Sequence (st_bi) ---
% Station 1 = depot (D=0, T=0, no charging needed)
% Corrected: no index 0, proper padding
st_bi = array2d(1..5, 1..8, [
  1,2,8,8,6,3,3,3,  % Bus 1: 6 stops + padding
  1,9,2,7,9,9,9,9,  % Bus 2: 5 stops + padding
  1,2,5,7,4,4,4,4,  % Bus 3: 5 stops + padding
  1,4,10,3,3,5,7,9, % Bus 4: 8 stops
  1,2,9,3,4,6,6,6   % Bus 5: 6 stops + padding
]);

% --- Energy Consumption (D) ---
% Scaled ×10 (kWh × 10)
% High consumption to force charging
D = array2d(1..5, 1..8, [
  0,250,200,150,200,250,0,0,  % Bus 1: 1050 total - MUST charge
  0,300,250,200,150,0,0,0,    % Bus 2: 900 total - MUST charge
  0,250,200,300,200,0,0,0,    % Bus 3: 950 total - MUST charge
  0,150,200,150,150,200,250,150, % Bus 4: 1250 total - MUST charge heavily
  0,200,250,200,300,150,0,0   % Bus 5: 1100 total - MUST charge
]);

% --- Travel Time (T) ---
% Scaled ×10 (minutes × 10)
T = array2d(1..5, 1..8, [
  0,120,150,140,200,160,0,0,  % Bus 1
  0,180,220,200,180,0,0,0,    % Bus 2
  0,220,200,240,190,0,0,0,    % Bus 3
  0,160,220,120,220,140,180,150, % Bus 4
  0,180,240,140,150,180,0,0   % Bus 5
]);

% --- Timetable (tau_bi) ---
% Scaled ×10 (minutes × 10)
% Starting at 7:00 AM (4200 = 420.0 minutes)
tau_bi = array2d(1..5, 1..8, [
  4200,4320,4470,4610,4810,4970,4970,4970,  % Bus 1
  4200,4380,4600,4800,4980,4980,4980,4980,  % Bus 2
  4200,4420,4620,4860,5050,5050,5050,5050,  % Bus 3
  4200,4360,4580,4700,4920,5060,5240,5390,  % Bus 4
  4200,4380,4620,4760,4910,5090,5090,5090   % Bus 5
]);
